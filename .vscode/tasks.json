{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build minidb",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17", "-O2", "-Wall", "-Wextra", "-static",
                "-o", "minidb.exe",
                "src/main.cpp"
            ],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": "$gcc",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "Build minidb (debug)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17", "-g", "-O0", "-Wall", "-Wextra",
                "-o", "minidb_dbg.exe",
                "src/main.cpp"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "Build run_tests",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17", "-O2", "-Wall", "-Wextra", "-static",
                "-o", "run_tests.exe",
                "tests/test_main.cpp"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "Build run_tests (debug)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17", "-g", "-O0", "-Wall", "-Wextra",
                "-o", "run_tests_dbg.exe",
                "tests/test_main.cpp"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "./run_tests.exe",
            "dependsOn": "Build run_tests",
            "group": { "kind": "test", "isDefault": true },
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared" }
        }
    ]
}
