{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run minidb (Iris + SpeciesInfo)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/minidb_dbg.exe",
            "args": ["data/Iris.csv", "data/SpeciesInfo.csv"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "Build minidb (debug)",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Run minidb (Iris only)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/minidb_dbg.exe",
            "args": ["data/Iris.csv"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "Build minidb (debug)"
        },
        {
            "name": "Run minidb (--bench)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/minidb_dbg.exe",
            "args": ["--bench"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "Build minidb (debug)"
        },
        {
            "name": "Run tests (debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/run_tests_dbg.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "preLaunchTask": "Build run_tests (debug)"
        }
    ]
}
